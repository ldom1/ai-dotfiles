# Copy this file to brain.env and set your vault path.
# cp config/brain.env.example config/brain.env

# Absolute path to your Local Brain Obsidian vault (must be a git repo).
#
# WSL (Windows + WSL2):
# BRAIN_PATH=/mnt/c/Users/<you>/Documents/Local Brain
#
# macOS:
# BRAIN_PATH=/Users/<you>/Documents/ObsidianVault
#
# Linux:
# BRAIN_PATH=/home/<you>/brain
BRAIN_PATH=

# Path to the QMD SQLite index file for semantic search over the vault.
# The parent directory must exist before running `qmd collection add`.
# Example: QMD_INDEX_PATH=/home/<you>/vault-qmd/brain.db
QMD_INDEX_PATH=

# Export both so hooks and child processes see them without re-sourcing.
# Add to ~/.zshrc: source ~/ai-dotfiles/config/brain.env
export BRAIN_PATH
export QMD_INDEX_PATH
