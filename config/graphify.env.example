# Copy to graphify.env and set your clone path (optional — only if you use `uv run` from a graphify git checkout).
# cp config/graphify.env.example config/graphify.env
#
# Absolute path to the graphify project root (directory containing uv.lock).
# WSL:  GRAPHIFY_PROJECT=/home/you/lab/graphify
# macOS: GRAPHIFY_PROJECT=/Users/you/src/graphify
GRAPHIFY_PROJECT=
