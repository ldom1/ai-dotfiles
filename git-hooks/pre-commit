#!/bin/sh
# ── 1. Block Cursor runtime dirs ─────────────────────────────────────────────
FORBIDDEN=".cursor/plugins .cursor/projects .cursor/skills-cursor .cursor/plans"

for dir in $FORBIDDEN; do
  if /usr/bin/git diff --cached --name-only --diff-filter=AM | /bin/grep "^${dir}/" | /bin/grep -qv '\.gitignore$'; then
    echo "ERROR: refusing to commit files under ${dir}/"
    echo "Run: git rm --cached -r ${dir}/"
    exit 1
  fi
done

# ── 2. Scan staged content for secrets ───────────────────────────────────────
# Read staged file contents directly (avoids git diff format issues)
SECRET_PATTERNS='ghp_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{80,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY|sk-[A-Za-z0-9]{40,}|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy][[:space:]]*[:=][[:space:]]*[\"'"'"']?[A-Za-z0-9_-]{20,}|[Bb]earer [A-Za-z0-9_.-]{20,}'

MATCHES=""
while IFS= read -r file; do
  HIT=$(/usr/bin/git show ":$file" 2>/dev/null | /bin/grep -oE "$SECRET_PATTERNS" | head -3)
  if [ -n "$HIT" ]; then
    MATCHES="$MATCHES $file"
  fi
done << EOF
$(/usr/bin/git diff --cached --name-only --diff-filter=AM)
EOF

if [ -n "$MATCHES" ]; then
  echo "ERROR: possible secret(s) detected in staged file(s):$MATCHES"
  echo ""
  echo "If this is a false positive, use: git commit --no-verify"
  exit 1
fi
