# Local Brain Vault Configuration
# =================================
# Copy this file to your environment or ~/ai-dotfiles/config/brain.env
# and set BRAIN_PATH to your Local Brain directory absolute path

# Local Brain vault path (absolute path required)
# The path should point to the root directory of your Local Brain obsidian vault
BRAIN_PATH=/path/to/your/Local\ Brain

# Optional: Override default audit output directory
# (default: $BRAIN_PATH/resources/queries)
AUDIT_OUTPUT_DIR=$BRAIN_PATH/resources/queries

# Optional: Enable verbose logging during audit runs
# (default: false)
AUDIT_VERBOSE=false

# Optional: Maximum concurrent processing threads for Phase 1
# (default: 4)
AUDIT_THREADS=4
