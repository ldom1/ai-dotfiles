{
  "project_types": {
    "nextjs": {
      "detect": ["next.config.js", "next.config.ts", "next.config.mjs"],
      "scopes": ["core", "ci", "design", "docs", "ui", "api", "auth", "tests", "config", "vulnerability"]
    },
    "python": {
      "detect": ["pyproject.toml", "uv.lock", "setup.py"],
      "scopes": ["core", "ci", "design", "docs", "api", "tests", "config", "vulnerability", "storage"]
    },
    "ansible": {
      "detect": ["ansible.cfg", "site.yml", "playbook.yml", "roles"],
      "scopes": ["core", "ci", "design", "docs", "roles", "inventory", "config", "tests", "vulnerability"]
    },
    "ai-dotfiles": {
      "detect": ["skills/brain-sync", ".claude/skills", "skills/review"],
      "scopes": ["skill", "claude", "config", "scripts", "core", "ci", "design", "docs"]
    },
    "validation": {
      "detect": ["docs/srd", "inventory", "fixtures/jupyter"],
      "scopes": ["core", "docs", "inventory", "fixtures", "scripts", "user", "slurm", "jupyter", "monitoring", "service"]
    },
    "brain-vault": {
      "detect": [".obsidian"],
      "scopes": ["specs", "plans", "decisions", "digest", "projects", "sop", "config"]
    }
  }
}
